# ─── Sitio (producción / Coolify) ───────────────────────────────────────────
# URL pública con https, sin barra final. Usada en build (sitemap, OG) y logs.
SITE_URL=https://tudominio.com

# Email visible en Schema.org (opcional; por defecto info@tudominio.com)
# PUBLIC_CONTACT_EMAIL=info@tudominio.com

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

SESSION_SECRET=genera-una-cadena-larga-aleatoria
ADMIN_PASSWORD=tu-contraseña-plana
# Solo si usas hash bcrypt (npm run admin:hash). Si está mal, se ignora y se usa ADMIN_PASSWORD.
# ADMIN_PASSWORD_HASH=

# Vacío o "auto" (recomendado detrás de Coolify/HTTPS). true = forzar Secure. false = solo HTTP (pruebas).
# COOKIE_SECURE=auto

RESTAURANT_MAX_COVERS_PER_TIMESLOT=40
MAX_BOOKING_DAYS_AHEAD=120
BOOKING_MIN_LEAD_MINUTES=30

# ─── SMTP (reservas) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="La Cerámica <reservas@tudominio.com>"
MAIL_BCC=

# ─── Docker Compose (opcional) ────────────────────────────────────────────────
# HOST_PORT=3000
