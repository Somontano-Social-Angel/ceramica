---
import Layout from "../layouts/Layout.astro";
import { useTranslations } from "../i18n";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import SectionNosotros from "../components/SectionNosotros.astro";
import SectionFirma from "../components/SectionFirma.astro";
import SectionCarta from "../components/SectionCarta.astro";
import SectionNovedades from "../components/SectionNovedades.astro";
import SectionExperiencia from "../components/SectionExperiencia.astro";
import SectionHorario from "../components/SectionHorario.astro";
import SectionTestimonios from "../components/SectionTestimonios.astro";
import SectionUbicacion from "../components/SectionUbicacion.astro";
import SectionFAQ from "../components/SectionFAQ.astro";
import SectionReserva from "../components/SectionReserva.astro";
import Footer from "../components/Footer.astro";
import "../styles/home-mobile.css";
---

<Layout
  title={t("meta.homeTitle")}
  description={t("meta.homeDesc")}
  canonicalPath="/"
>
  <a class="skip" href="#inicio">{t("skip")}</a>
  <Header />
  <main class="home-main" transition:animate="fade">
    <Hero />
    <div class="home-mobile-lite">
      <SectionNosotros />
      <SectionFirma />
      <SectionNovedades />
      <SectionExperiencia />
      <SectionTestimonios />
      <SectionFAQ />
    </div>
    <SectionCarta />
    <SectionHorario />
    <SectionUbicacion />
    <SectionReserva />
  </main>
  <Footer />
</Layout>

<style>
  .skip {
    position: fixed;
    top: 0;
    left: 50%;
    z-index: 100;
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--bg);
    background: var(--fg);
    border-radius: 0 0 8px 8px;
    transform: translate(-50%, -120%);
    transition: transform 0.25s var(--ease-out);
  }

  .skip:focus {
    transform: translate(-50%, 0);
  }

  @media (max-width: 959px) {
    .home-mobile-lite {
      display: none;
    }
  }
</style>
