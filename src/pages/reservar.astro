---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import OfflineNotice from "../components/OfflineNotice.astro";
import { getReservarClientI18n, useTranslations } from "../i18n";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
const ri18n = getReservarClientI18n(locale);
const reservarI18nJson = JSON.stringify(ri18n);
---

<Layout
  title={t("meta.reservarTitle")}
  description={t("meta.reservarDesc")}
  canonicalPath="/reservar"
>
  <Header />
  <main class="page" id="reservar-app" transition:animate="fade">
    <div class="shell">
      <OfflineNotice message={t("reservar.offlineNotice")} />
      <header class="page-head">
        <p class="eyebrow">{t("reservar.eyebrow")}</p>
        <h1 class="h1">{t("reservar.title")}</h1>
        <p class="lead">{t("reservar.lead")}</p>
      </header>

      <div class="layout">
        <section class="panel" aria-labelledby="cal-title">
          <h2 id="cal-title" class="h2">{t("reservar.step1")}</h2>
          <p class="api-banner" id="api-banner" hidden>
            {t("reservar.apiBanner")}
          </p>
          <div class="res-cal" id="res-cal" aria-labelledby="cal-picker-label">
            <p class="lbl res-cal__lbl" id="cal-picker-label">{t("reservar.pickDay")}</p>
            <div class="res-cal__toolbar">
              <button type="button" class="res-cal__nav" id="cal-prev" aria-label={t("reservar.prevMonth")}>
                <span class="res-cal__nav-icon" aria-hidden="true">‹</span>
              </button>
              <h3 class="res-cal__month" id="cal-month-label">—</h3>
              <button type="button" class="res-cal__nav" id="cal-next" aria-label={t("reservar.nextMonth")}>
                <span class="res-cal__nav-icon" aria-hidden="true">›</span>
              </button>
            </div>
            <div class="res-cal__dow" aria-hidden="true">
              {ri18n.dow.map((d) => <span>{d}</span>)}
            </div>
            <div class="res-cal__grid" id="cal-grid" role="grid" aria-labelledby="cal-picker-label"></div>
            <input type="hidden" id="date-input" autocomplete="off" />
          </div>
          <div class="clock" id="clock-line" hidden>
            <div class="clock__row">
              <span class="clock__label">{t("reservar.spainTime")}</span>
              <time class="clock__time" id="clock-time" datetime=""></time>
            </div>
            <p class="clock__hint" id="clock-hint"></p>
          </div>
          <p class="hint" id="closed-msg" hidden>{t("reservar.closed")}</p>
          <p class="info-msg" id="no-slots-msg" hidden></p>
          <div class="slots-wrap" id="slots-wrap" hidden>
            <div class="slot-groups" id="slots" aria-live="polite"></div>
          </div>
        </section>

        <section class="panel" aria-labelledby="form-title">
          <h2 id="form-title" class="h2">{t("reservar.step2")}</h2>
          <form class="form" id="res-form">
            <input type="hidden" name="time" id="time-hidden" />
            <label class="lbl"> {t("reservar.pickedTime")} <span class="picked" id="picked-time">—</span> </label>
            <label class="lbl" for="party">{t("reservar.party")}</label>
            <input class="inp" type="number" id="party" name="partySize" min="1" max="20" value="2" required />

            <label class="lbl" for="name">{t("reservar.name")}</label>
            <input class="inp" type="text" id="name" name="name" autocomplete="name" required maxlength="80" />

            <label class="lbl" for="email">{t("reservar.email")}</label>
            <input class="inp" type="email" id="email" name="email" autocomplete="email" required />

            <label class="lbl" for="phone">{t("reservar.phone")}</label>
            <input class="inp" type="tel" id="phone" name="phone" autocomplete="tel" required />

            <fieldset class="fs">
              <legend class="lbl">{t("reservar.zone")}</legend>
              <label class="chk"><input type="checkbox" name="svc" value="Terraza" /> {t("reservar.terrace")}</label>
              <label class="chk"><input type="checkbox" name="svc" value="Interior" /> {t("reservar.interior")}</label>
              <label class="chk"><input type="checkbox" name="svc" value="Zona barra" /> {t("reservar.bar")}</label>
            </fieldset>

            <label class="lbl" for="notes">{t("reservar.notes")}</label>
            <textarea class="inp ta" id="notes" name="notes" maxlength="500" rows="3" placeholder={t("reservar.notesPh")}></textarea>

            <p class="err" id="form-err" hidden></p>
            <p class="ok" id="form-ok" hidden></p>
            <p class="ok-actions" id="form-ok-actions" hidden>
              <button type="button" class="ics-btn" id="ics-btn">{t("reservar.ics")}</button>
            </p>

            <button class="submit" type="submit" id="submit-btn">{t("reservar.submit")}</button>
          </form>
        </section>
      </div>

      <p class="fine">
        La Cerámica · C. Cerámica Industrial VI, 13, 22300 Barbastro · <a href="tel:+34974312220">974 31 22 20</a>
      </p>
    </div>
  </main>
  <Footer />
</Layout>

<script define:vars={{ reservarI18nJson }} data-astro-rerun>
  const i18n = JSON.parse(reservarI18nJson);

  /** Referencias al DOM actuales (se refrescan en cada visita por View Transitions). */
  /** @type {ReturnType<typeof syncDom> | null} */
  let dom = null;

  function syncDom() {
    const root = document.getElementById("reservar-app");
    if (!root) return null;
    const dateInput = /** @type {HTMLInputElement | null} */ (root.querySelector("#date-input"));
    const calGrid = /** @type {HTMLDivElement | null} */ (root.querySelector("#cal-grid"));
    const calMonthLabel = /** @type {HTMLHeadingElement | null} */ (root.querySelector("#cal-month-label"));
    const calPrev = /** @type {HTMLButtonElement | null} */ (root.querySelector("#cal-prev"));
    const calNext = /** @type {HTMLButtonElement | null} */ (root.querySelector("#cal-next"));
    const slotsEl = root.querySelector("#slots");
    const slotsWrap = root.querySelector("#slots-wrap");
    const form = root.querySelector("#res-form");
    const submitBtn = root.querySelector("#submit-btn");
    const closedMsg = root.querySelector("#closed-msg");
    const noSlotsMsg = root.querySelector("#no-slots-msg");
    const clockLine = root.querySelector("#clock-line");
    const clockTime = root.querySelector("#clock-time");
    const clockHint = root.querySelector("#clock-hint");
    const timeHidden = root.querySelector("#time-hidden");
    const pickedTime = root.querySelector("#picked-time");
    const formErr = root.querySelector("#form-err");
    const formOk = root.querySelector("#form-ok");
    const formOkActions = root.querySelector("#form-ok-actions");
    if (
      !dateInput ||
      !calGrid ||
      !calMonthLabel ||
      !calPrev ||
      !calNext ||
      !slotsEl ||
      !slotsWrap ||
      !form ||
      !submitBtn ||
      !closedMsg ||
      !noSlotsMsg ||
      !clockLine ||
      !clockTime ||
      !clockHint ||
      !timeHidden ||
      !pickedTime ||
      !formErr ||
      !formOk ||
      !formOkActions
    ) {
      return null;
    }
    return {
      root,
      dateInput,
      calGrid,
      calMonthLabel,
      calPrev,
      calNext,
      apiBanner: /** @type {HTMLParagraphElement | null} */ (root.querySelector("#api-banner")),
      slotsEl: /** @type {HTMLDivElement} */ (slotsEl),
      slotsWrap: /** @type {HTMLDivElement} */ (slotsWrap),
      closedMsg: /** @type {HTMLParagraphElement} */ (closedMsg),
      noSlotsMsg: /** @type {HTMLParagraphElement} */ (noSlotsMsg),
      clockLine: /** @type {HTMLDivElement} */ (clockLine),
      clockTime: /** @type {HTMLTimeElement} */ (clockTime),
      clockHint: /** @type {HTMLParagraphElement} */ (clockHint),
      timeHidden: /** @type {HTMLInputElement} */ (timeHidden),
      pickedTime: /** @type {HTMLSpanElement} */ (pickedTime),
      form: /** @type {HTMLFormElement} */ (form),
      formErr: /** @type {HTMLParagraphElement} */ (formErr),
      formOk: /** @type {HTMLParagraphElement} */ (formOk),
      formOkActions: /** @type {HTMLParagraphElement} */ (formOkActions),
      icsBtn: /** @type {HTMLButtonElement | null} */ (root.querySelector("#ics-btn")),
      submitBtn: /** @type {HTMLButtonElement} */ (submitBtn),
    };
  }

  /** @type {{ id: string; date: string; time: string; partySize: number; name: string; notes: string; services: string[] } | null} */
  let lastReservation = null;

  let selectedTime = "";
  /** @type {string} */
  let metaToday = "";
  /** @type {string} */
  let metaMaxBookable = "";
  /** @type {number} */
  let metaMaxAhead = 120;
  let viewYear = 0;
  let viewMonth = 0;

  function madridDateStringClient() {
    return new Date().toLocaleDateString("sv-SE", { timeZone: "Europe/Madrid" });
  }

  function addDaysISO(dateStr, delta) {
    const [y, m, d] = dateStr.split("-").map(Number);
    const dt = new Date(Date.UTC(y, m - 1, d + delta));
    const yy = dt.getUTCFullYear();
    const mm = String(dt.getUTCMonth() + 1).padStart(2, "0");
    const dd = String(dt.getUTCDate()).padStart(2, "0");
    return `${yy}-${mm}-${dd}`;
  }

  /** 0=dom … 6=sáb (Madrid) */
  function madridWeekday(dateStr) {
    const [y, mo, d] = dateStr.split("-").map(Number);
    const utcNoon = Date.UTC(y, mo - 1, d, 12, 0, 0);
    const short = new Intl.DateTimeFormat("en-US", {
      timeZone: "Europe/Madrid",
      weekday: "short",
    }).format(new Date(utcNoon));
    /** @type {Record<string, number>} */
    const map = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 };
    return map[short] ?? 0;
  }

  function mondayFirstColumnClient(firstDateStr) {
    return (madridWeekday(firstDateStr) + 6) % 7;
  }

  function diffCalendarDays(a, b) {
    const [y1, m1, d1] = a.split("-").map(Number);
    const [y2, m2, d2] = b.split("-").map(Number);
    return Math.round((Date.UTC(y1, m1 - 1, d1) - Date.UTC(y2, m2 - 1, d2)) / 86400000);
  }

  /** Primer día no domingo ≥ today (sin API). */
  function suggestedDateClient(today) {
    let d = today;
    for (let i = 0; i < 14; i++) {
      if (madridWeekday(d) !== 0 && d >= today) return d;
      d = addDaysISO(d, 1);
    }
    return today;
  }

  function isReservarPage() {
    return location.pathname.includes("/reservar");
  }

  function daysInMonthHuman(y, m) {
    return new Date(y, m, 0).getDate();
  }

  /** Igual que el servidor: domingo cerrado. */
  function buildLocalMonthPack(y, m) {
    const today = metaToday || madridDateStringClient();
    const dim = daysInMonthHuman(y, m);
    const first = `${y}-${String(m).padStart(2, "0")}-01`;
    const leadingEmpty = mondayFirstColumnClient(first);
    const days = [];
    for (let d = 1; d <= dim; d++) {
      const dateStr = `${y}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
      const closed = madridWeekday(dateStr) === 0;
      const past = dateStr < today;
      const tooFar = diffCalendarDays(dateStr, today) > metaMaxAhead;
      days.push({ date: dateStr, closed, past, tooFar, disabled: past || closed || tooFar });
    }
    return { leadingEmpty, days };
  }

  const MESES = i18n.months;

  function monthKey(y, m) {
    return y * 12 + (m - 1);
  }

  function requireDom() {
    dom = syncDom();
    return dom;
  }

  function syncViewFromInput() {
    if (!dom) return;
    const v = dom.dateInput.value;
    if (!/^\d{4}-\d{2}-\d{2}$/.test(v)) return;
    viewYear = parseInt(v.slice(0, 4), 10);
    viewMonth = parseInt(v.slice(5, 7), 10);
  }

  function updateNavDisabled() {
    if (!dom || !metaToday || !metaMaxBookable) return;
    const viewK = monthKey(viewYear, viewMonth);
    const minK = monthKey(parseInt(metaToday.slice(0, 4), 10), parseInt(metaToday.slice(5, 7), 10));
    const maxK = monthKey(parseInt(metaMaxBookable.slice(0, 4), 10), parseInt(metaMaxBookable.slice(5, 7), 10));
    dom.calPrev.disabled = viewK <= minK;
    dom.calNext.disabled = viewK >= maxK;
  }

  async function renderCalendar() {
    if (!requireDom()) return;
    if (!viewYear || !viewMonth) {
      const t = metaToday || madridDateStringClient();
      viewYear = parseInt(t.slice(0, 4), 10);
      viewMonth = parseInt(t.slice(5, 7), 10);
    }
    updateNavDisabled();
    dom.calMonthLabel.textContent = `${MESES[viewMonth - 1]} ${viewYear}`;
    let pack = null;
    try {
      const r = await fetch(`/api/calendar-month?year=${viewYear}&month=${viewMonth}`);
      const j = r.ok ? await r.json() : null;
      if (r.ok && j?.ok && Array.isArray(j.days) && j.days.length > 0) {
        pack = { leadingEmpty: Number(j.leadingEmpty ?? 0), days: j.days };
      }
    } catch {
      pack = null;
    }
    if (!pack) {
      pack = buildLocalMonthPack(viewYear, viewMonth);
    }
    dom.calGrid.innerHTML = "";
    for (let i = 0; i < pack.leadingEmpty; i++) {
      const pad = document.createElement("div");
      pad.className = "res-cal__pad";
      pad.setAttribute("aria-hidden", "true");
      dom.calGrid.appendChild(pad);
    }
    for (const day of pack.days) {
      const b = document.createElement("button");
      b.type = "button";
      b.className = "res-cal__day";
      b.dataset.date = day.date;
      const dayNum = parseInt(day.date.slice(8, 10), 10);
      b.textContent = String(dayNum);
      if (day.disabled) {
        b.disabled = true;
        b.classList.add("res-cal__day--off");
        if (day.closed) b.classList.add("res-cal__day--closed");
        b.title = day.past ? i18n.calendarPast : day.tooFar ? i18n.calendarTooFar : i18n.calendarClosed;
      } else {
        b.title = i18n.calendarPick;
      }
      if (day.date === metaToday) b.classList.add("res-cal__day--today");
      if (day.date === dom.dateInput.value && !day.disabled) b.classList.add("res-cal__day--picked");
      b.addEventListener("click", () => {
        if (day.disabled) return;
        if (!requireDom()) return;
        dom.dateInput.value = day.date;
        syncViewFromInput();
        renderCalendar().then(() => {
          loadSlots();
          armPoll();
        });
      });
      dom.calGrid.appendChild(b);
    }
  }

  async function loadMeta() {
    if (!requireDom()) return;
    if (dom.apiBanner) dom.apiBanner.hidden = true;
    try {
      const r = await fetch("/api/meta");
      const j = r.ok ? await r.json() : null;
      if (!r.ok || !j?.ok || !j.today) throw new Error("meta");
      metaToday = j.today;
      metaMaxBookable = j.maxBookableDate || addDaysISO(j.today, Number(j.maxBookingDaysAhead ?? 120));
      metaMaxAhead = Number(j.maxBookingDaysAhead ?? 120);
      dom.dateInput.value = j.suggestedDate || j.today;
      syncViewFromInput();
      if (j?.nowMadrid) {
        dom.clockTime.textContent = j.nowMadrid;
        dom.clockTime.setAttribute("datetime", new Date().toISOString());
        const lead = Number(j.minLeadMinutes ?? 30);
        dom.clockHint.textContent = i18n.clockHintLead.replace("{lead}", String(lead));
        dom.clockLine.hidden = false;
      }
    } catch {
      metaToday = madridDateStringClient();
      metaMaxAhead = 120;
      metaMaxBookable = addDaysISO(metaToday, metaMaxAhead);
      dom.dateInput.value = suggestedDateClient(metaToday);
      syncViewFromInput();
      if (dom.apiBanner) dom.apiBanner.hidden = false;
      dom.clockTime.textContent = new Intl.DateTimeFormat("es-ES", {
        timeZone: "Europe/Madrid",
        dateStyle: "medium",
        timeStyle: "short",
      }).format(new Date());
      dom.clockHint.textContent = i18n.clockHintNoApi;
      dom.clockLine.hidden = false;
    }
  }

  function setPicked(t) {
    if (!dom) return;
    selectedTime = t;
    dom.timeHidden.value = t;
    if (t) {
      const [hh, mm] = t.split(":");
      dom.pickedTime.innerHTML = `<span class="picked__big">${hh}<span class="picked__sep">:</span>${mm}</span>`;
    } else {
      dom.pickedTime.textContent = "—";
    }
  }

  /** @param {string} t */
  function makeSlotButton(t, full, max, cov) {
    const b = document.createElement("button");
    b.type = "button";
    b.className = "slot" + (full ? " slot--full" : "");
    b.setAttribute("aria-pressed", "false");
    b.innerHTML = `<span class="slot__time">${t}</span>`;
    b.disabled = full;
    b.title = full
      ? i18n.slotFull
      : cov > 0
        ? i18n.slotCovers.replace("{cov}", String(cov)).replace("{max}", String(max))
        : i18n.slotAvail;
    b.addEventListener("click", () => {
      if (!dom) return;
      dom.slotsEl.querySelectorAll(".slot").forEach((x) => {
        x.classList.remove("slot--on");
        x.setAttribute("aria-pressed", "false");
      });
      if (!full) {
        b.classList.add("slot--on");
        b.setAttribute("aria-pressed", "true");
        setPicked(t);
      }
    });
    return b;
  }

  /** @param {string[]} slots */
  function splitDayParts(slots) {
    const day = slots.filter((t) => t < "20:00");
    const eve = slots.filter((t) => t >= "20:00");
    return { day, eve };
  }

  async function loadSlots(allowSuggest = true) {
    if (!requireDom()) return;
    dom.formErr.hidden = true;
    dom.closedMsg.hidden = true;
    dom.noSlotsMsg.hidden = true;
    dom.slotsWrap.hidden = true;
    dom.slotsEl.innerHTML = "";
    setPicked("");
    const d = dom.dateInput.value;
    if (!d) {
      dom.noSlotsMsg.textContent = i18n.pickDay;
      dom.noSlotsMsg.hidden = false;
      return;
    }
    let j;
    try {
      const r = await fetch(`/api/slots?date=${encodeURIComponent(d)}`);
      if (!r.ok) {
        dom.noSlotsMsg.textContent = i18n.slotsLoad;
        dom.noSlotsMsg.hidden = false;
        return;
      }
      j = await r.json();
    } catch {
      dom.noSlotsMsg.textContent = i18n.slotsLoad;
      dom.noSlotsMsg.hidden = false;
      return;
    }
    if (!j?.ok) {
      dom.noSlotsMsg.textContent = j?.error || i18n.slotsLoad;
      dom.noSlotsMsg.hidden = false;
      return;
    }

    if (j.nowMadrid) dom.clockTime.textContent = j.nowMadrid;
    if (j.minLeadMinutes != null) {
      dom.clockHint.textContent = i18n.clockHintLead.replace("{lead}", String(j.minLeadMinutes));
    }
    dom.clockLine.hidden = false;

    if (j.closed) {
      if (allowSuggest && j.suggestedDate && j.suggestedDate !== d) {
        dom.dateInput.value = j.suggestedDate;
        syncViewFromInput();
        await renderCalendar();
        return loadSlots(false);
      }
      dom.closedMsg.hidden = false;
      return;
    }
    if (j.noSlotsLeft || !j.slots?.length) {
      if (allowSuggest && j.suggestedDate && j.suggestedDate !== d) {
        dom.dateInput.value = j.suggestedDate;
        syncViewFromInput();
        await renderCalendar();
        return loadSlots(false);
      }
      dom.noSlotsMsg.textContent = i18n.noSlots;
      dom.noSlotsMsg.hidden = false;
      return;
    }

    dom.slotsWrap.hidden = false;
    const booked = j.bookedCovers ?? {};
    const max = j.maxCoversPerSlot ?? 40;
    const { day, eve } = splitDayParts(j.slots);

    function appendGroup(title, list) {
      if (!list.length) return;
      const grp = document.createElement("div");
      grp.className = "slot-group";
      const h = document.createElement("h3");
      h.className = "slot-group__title";
      h.textContent = title;
      const grid = document.createElement("div");
      grid.className = "slot-grid";
      for (const t of list) {
        const cov = booked[t] ?? 0;
        const full = cov >= max;
        grid.appendChild(makeSlotButton(t, full, max, cov));
      }
      grp.appendChild(h);
      grp.appendChild(grid);
      dom.slotsEl.appendChild(grp);
    }

    appendGroup(i18n.morning, day);
    appendGroup(i18n.evening, eve);
  }

  /** @type {ReturnType<typeof setInterval> | null} */
  let pollId = null;
  function armPoll() {
    if (pollId) clearInterval(pollId);
    pollId = null;
    if (dom && metaToday && dom.dateInput.value === metaToday) {
      pollId = setInterval(loadSlots, 60_000);
    }
  }

  async function bootstrapReservar() {
    try {
      if (!requireDom()) {
        requestAnimationFrame(() => bootstrapReservar());
        return;
      }
      await loadMeta();
      await renderCalendar();
      await loadSlots();
      armPoll();
    } catch (err) {
      console.error("[reservar] bootstrap:", err);
    }
  }

  function setupReservarUi() {
    const win = /** @type {Window & { __reservarUiBound?: boolean }} */ (window);
    if (win.__reservarUiBound) return;
    win.__reservarUiBound = true;

    document.addEventListener("click", async (e) => {
      if (!isReservarPage()) return;
      const t = e.target;
      if (!(t instanceof Element)) return;

      if (t.closest("#cal-prev")) {
        if (!requireDom() || dom.calPrev.disabled) return;
        if (viewMonth <= 1) {
          viewYear -= 1;
          viewMonth = 12;
        } else {
          viewMonth -= 1;
        }
        await renderCalendar();
        return;
      }
      if (t.closest("#cal-next")) {
        if (!requireDom() || dom.calNext.disabled) return;
        if (viewMonth >= 12) {
          viewYear += 1;
          viewMonth = 1;
        } else {
          viewMonth += 1;
        }
        await renderCalendar();
      }
    });

    document.addEventListener("submit", async (e) => {
      if (!isReservarPage()) return;
      const formEl = e.target;
      if (!(formEl instanceof HTMLFormElement) || formEl.id !== "res-form") return;
      e.preventDefault();
      if (!requireDom()) return;
      dom.formErr.hidden = true;
      dom.formOk.hidden = true;
      dom.formOkActions.hidden = true;
      if (!selectedTime) {
        dom.formErr.textContent = i18n.pickTime;
        dom.formErr.hidden = false;
        return;
      }
      const svc = [...formEl.querySelectorAll('input[name="svc"]:checked')].map(
        (x) => /** @type {HTMLInputElement} */ (x).value,
      );
      const body = {
        date: dom.dateInput.value,
        time: selectedTime,
        partySize: Number(/** @type {HTMLInputElement} */ (dom.root.querySelector("#party")).value),
        name: /** @type {HTMLInputElement} */ (dom.root.querySelector("#name")).value.trim(),
        email: /** @type {HTMLInputElement} */ (dom.root.querySelector("#email")).value.trim(),
        phone: /** @type {HTMLInputElement} */ (dom.root.querySelector("#phone")).value.trim(),
        notes: /** @type {HTMLTextAreaElement} */ (dom.root.querySelector("#notes")).value.trim(),
        services: svc,
      };
      dom.submitBtn.disabled = true;
      try {
        const r = await fetch("/api/reservations", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const j = await r.json();
        if (!r.ok) throw new Error(j.error || i18n.submitError);
        lastReservation = {
          id: j.id,
          date: body.date,
          time: body.time,
          partySize: body.partySize,
          name: body.name,
          notes: body.notes,
          services: body.services,
        };
        dom.formOk.textContent = i18n.ok.replace("{id}", j.id);
        dom.formOk.hidden = false;
        dom.formOkActions.hidden = false;
        formEl.reset();
        setPicked("");
        try {
          const mr = await fetch("/api/meta");
          const mj = mr.ok ? await mr.json() : null;
          dom.dateInput.value = mj?.suggestedDate || mj?.today || metaToday;
        } catch {
          dom.dateInput.value = suggestedDateClient(metaToday || madridDateStringClient());
        }
        syncViewFromInput();
        await renderCalendar();
        await loadSlots();
        armPoll();
      } catch (err) {
        dom.formErr.textContent = err instanceof Error ? err.message : i18n.genericError;
        dom.formErr.hidden = false;
      } finally {
        dom.submitBtn.disabled = false;
      }
    });

    document.addEventListener("click", async (e) => {
      if (!isReservarPage()) return;
      const t = e.target;
      if (!(t instanceof Element)) return;
      if (t.closest("#ics-btn") && lastReservation) {
        const { buildReservationIcs, downloadIcs } = await import("../utils/ics");
        const content = buildReservationIcs(lastReservation);
        downloadIcs(content, `reserva-la-ceramica-${lastReservation.id}.ics`);
      }
    });

    document.addEventListener("astro:page-load", () => {
      if (isReservarPage()) bootstrapReservar();
    });
  }

  setupReservarUi();
  if (isReservarPage()) bootstrapReservar();
</script>

