---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CartaApp from "../components/CartaApp.astro";
import OfflineNotice from "../components/OfflineNotice.astro";
import { loadCarta } from "../data/carta";
import {
  getAlergenoLabels,
  getCartaUiStrings,
  getDietaLabels,
  lpath,
  useTranslations,
} from "../i18n";
import type { Locale } from "../i18n/types";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
const carta = loadCarta(locale as Locale);
const alergenoLabelsJson = JSON.stringify(getAlergenoLabels(locale));
const dietaLabelsJson = JSON.stringify(getDietaLabels(locale));
const uiStringsJson = JSON.stringify(getCartaUiStrings(locale));
---

<Layout
  title={t("meta.cartaTitle")}
  description={t("meta.cartaDesc")}
  canonicalPath="/carta"
>
  <a class="skip" href="#carta-app">{t("cartaPage.skip")}</a>
  <Header />
  <main class="page" transition:animate="fade">
    <div class="shell">
      <OfflineNotice message={t("cartaPage.offlineNotice")} />
      <header class="page-head">
        <p class="eyebrow">{t("cartaPage.eyebrow")}</p>
        <h1 class="h1">{t("cartaPage.title")}</h1>
        <p class="lead">{t("cartaPage.lead")}</p>
        <p class="menu-lang-note">{t("cartaPage.menuLangNote")}</p>
        <p class="print-link">
          <a href={lpath(locale, "/carta/imprimir")}>{t("cartaPage.print")}</a>
        </p>
      </header>
      <CartaApp
        carta={carta}
        alergenoLabelsJson={alergenoLabelsJson}
        dietaLabelsJson={dietaLabelsJson}
        uiStringsJson={uiStringsJson}
      />
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .skip {
    position: fixed;
    top: 0;
    left: 50%;
    z-index: 100;
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--bg);
    background: var(--fg);
    border-radius: 0 0 8px 8px;
    transform: translate(-50%, -120%);
    transition: transform 0.25s var(--ease-out);
  }

  .skip:focus {
    transform: translate(-50%, 0);
  }

  .page {
    padding: 5.25rem 0 3rem;
    min-height: 100vh;
  }

  @media (min-width: 640px) {
    .page {
      padding: 6.5rem 1.5rem 4rem;
    }
  }

  .shell {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 0.75rem;
  }

  @media (min-width: 640px) {
    .shell {
      padding: 0;
    }
  }

  .page-head {
    margin-bottom: 1.5rem;
    max-width: 42rem;
    padding: 0 0.5rem;
  }

  @media (min-width: 640px) {
    .page-head {
      margin-bottom: 2.5rem;
      padding: 0;
    }
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .h1 {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 600;
    line-height: 1.1;
    color: var(--fg);
  }

  .lead {
    margin: 0;
    color: var(--fg-muted);
    line-height: 1.75;
  }

  .menu-lang-note {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    color: var(--fg-subtle);
    line-height: 1.55;
  }

  .print-link {
    margin: 1rem 0 0;
    font-size: 0.9rem;
  }

  .print-link a {
    color: var(--fg-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .print-link a:hover {
    color: var(--fg);
  }
</style>
