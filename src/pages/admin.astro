---
import AdminLayout from "../layouts/AdminLayout.astro";
import BookingCalendar from "../components/BookingCalendar.astro";
import { getReservarClientI18n } from "../i18n";

const calI18n = getReservarClientI18n("es");
const calI18nJson = JSON.stringify(calI18n);
---

<AdminLayout title="Admin reservas | La Cerámica">
  <main class="adm">
    <section class="adm-card adm-card--login" id="login-panel">
      <p class="adm-brand">La Cerámica</p>
      <h1 class="adm-title">Panel de reservas</h1>
      <p class="adm-lead">Acceso restringido al personal.</p>
      <p class="adm-warn" id="api-warn" hidden>
        No hay conexión con la API. Arranca <code>npm run dev</code> o el servidor en producción.
      </p>
      <form class="adm-form" id="login-form" onsubmit="return false">
        <label class="adm-lbl" for="pwd">Contraseña</label>
        <input class="adm-inp" type="password" id="pwd" autocomplete="current-password" required />
        <p class="adm-err" id="login-err" hidden></p>
        <button class="adm-btn" type="submit">Entrar</button>
      </form>
      <p class="adm-back">
        <a class="adm-back__link" href="/">← Volver al inicio</a>
      </p>
    </section>

    <div class="adm-shell" id="dash-panel" aria-hidden="true" inert>
      <aside class="adm-side">
        <p class="adm-brand">La Cerámica</p>
        <nav class="adm-nav" aria-label="Secciones">
          <button class="adm-nav__btn is-active" type="button" data-nav="overview">Resumen</button>
          <button class="adm-nav__btn" type="button" data-nav="list">Todas</button>
          <button class="adm-nav__btn" type="button" data-nav="new">Nueva · teléfono</button>
          <button class="adm-nav__btn" type="button" data-nav="novedades">Qué hay de nuevo</button>
        </nav>
        <button class="adm-link" type="button" id="logout-btn">Cerrar sesión</button>
      </aside>

      <div class="adm-main">
        <!-- Resumen del día -->
        <section class="adm-panel is-active" id="panel-overview" data-panel="overview">
          <header class="adm-head">
            <div>
              <h1 class="adm-title adm-title--sm">Resumen</h1>
              <p class="adm-sub" id="overview-now"></p>
            </div>
            <button class="adm-btn adm-btn--ghost adm-btn--compact" type="button" id="ov-today">Hoy</button>
          </header>

          <div class="adm-overview-cal">
            <BookingCalendar
              calendarId="ov"
              label={calI18n.pickDay}
              pickDayLabel={calI18n.pickDay}
              prevMonthLabel="Mes anterior"
              nextMonthLabel="Mes siguiente"
              dow={calI18n.dow}
            />
          </div>

          <div class="adm-stats" id="stats-row" aria-live="polite"></div>

          <h2 class="adm-h2">Por franja</h2>
          <div class="adm-timeline" id="timeline"></div>
          <p class="adm-empty" id="timeline-empty" hidden>Sin reservas activas este día.</p>

          <h2 class="adm-h2">Próximos 7 días</h2>
          <div class="adm-week" id="week-strip"></div>
        </section>

        <!-- Listado -->
        <section class="adm-panel" id="panel-list" data-panel="list" hidden>
          <header class="adm-head">
            <h1 class="adm-title adm-title--sm">Todas las reservas</h1>
          </header>
          <div class="adm-filters adm-filters--cal">
            <div class="adm-cal-wrap">
              <BookingCalendar
                calendarId="list-from"
                label="Desde"
                pickDayLabel={calI18n.pickDay}
                prevMonthLabel="Mes anterior"
                nextMonthLabel="Mes siguiente"
                dow={calI18n.dow}
                compact
              />
            </div>
            <div class="adm-cal-wrap">
              <BookingCalendar
                calendarId="list-to"
                label="Hasta"
                pickDayLabel={calI18n.pickDay}
                prevMonthLabel="Mes anterior"
                nextMonthLabel="Mes siguiente"
                dow={calI18n.dow}
                compact
              />
            </div>
            <label class="adm-lbl adm-lbl--filter">Estado
              <select class="adm-inp" id="f-status">
                <option value="">Todas</option>
                <option value="pending">Pendiente</option>
                <option value="confirmed">Confirmada</option>
                <option value="cancelled">Cancelada</option>
              </select>
            </label>
            <button class="adm-btn adm-btn--ghost adm-btn--compact" type="button" id="reload-btn">Actualizar</button>
          </div>
          <div class="adm-cards" id="list-cards"></div>
          <p class="adm-empty" id="list-empty" hidden>Sin reservas en el rango.</p>
        </section>

        <!-- Alta manual -->
        <section class="adm-panel" id="panel-new" data-panel="new" hidden>
          <header class="adm-head">
            <h1 class="adm-title adm-title--sm">Nueva reserva por teléfono</h1>
            <p class="adm-sub">Se guarda como confirmada y aparece en el resumen del día.</p>
          </header>
          <form class="adm-form adm-form--wide" id="new-form">
            <div class="adm-new-cal">
              <BookingCalendar
                calendarId="new"
                label={calI18n.pickDay}
                pickDayLabel={calI18n.pickDay}
                prevMonthLabel="Mes anterior"
                nextMonthLabel="Mes siguiente"
                dow={calI18n.dow}
              />
            </div>
            <div class="adm-grid">
              <label class="adm-lbl">Hora
                <select class="adm-inp" name="time" id="new-time" required disabled>
                  <option value="">Cargando franjas…</option>
                </select>
              </label>
              <label class="adm-lbl">Personas
                <input class="adm-inp" type="number" name="partySize" min="1" max="20" value="2" required />
              </label>
              <label class="adm-lbl">Estado
                <select class="adm-inp" name="status" id="new-status">
                  <option value="confirmed" selected>Confirmada</option>
                  <option value="pending">Pendiente</option>
                </select>
              </label>
            </div>
            <div class="adm-grid">
              <label class="adm-lbl">Nombre
                <input class="adm-inp" name="name" autocomplete="name" required />
              </label>
              <label class="adm-lbl">Teléfono
                <input class="adm-inp" name="phone" type="tel" autocomplete="tel" required />
              </label>
              <label class="adm-lbl">Email <span class="adm-opt">(opcional)</span>
                <input class="adm-inp" name="email" type="email" autocomplete="email" placeholder="Si quieres enviar confirmación" />
              </label>
            </div>
            <fieldset class="adm-fieldset">
              <legend class="adm-lbl">Zona preferida</legend>
              <div class="adm-chips" id="new-services"></div>
            </fieldset>
            <label class="adm-lbl">Notas
              <textarea class="adm-inp adm-textarea" name="notes" rows="2" placeholder="Alergias, celebración…"></textarea>
            </label>
            <label class="adm-check">
              <input type="checkbox" name="sendEmail" id="new-send-email" />
              Enviar email de confirmación (solo si hay email)
            </label>
            <p class="adm-err" id="new-err" hidden></p>
            <p class="adm-ok" id="new-ok" hidden></p>
            <button class="adm-btn" type="submit">Guardar reserva</button>
          </form>
        </section>

        <section class="adm-panel" id="panel-novedades" data-panel="novedades" hidden>
          <header class="adm-head">
            <div>
              <h1 class="adm-title adm-title--sm">Qué hay de nuevo</h1>
              <p class="adm-sub">Publica avisos, menús o eventos en la home (español).</p>
            </div>
            <button class="adm-btn adm-btn--ghost adm-btn--compact" type="button" id="avisos-reload">Actualizar</button>
          </header>

          <form class="adm-form adm-form--wide" id="aviso-form">
            <div class="adm-grid">
              <label class="adm-lbl">Título
                <input class="adm-inp" name="title" required maxlength="160" />
              </label>
              <label class="adm-lbl">Tipo
                <select class="adm-inp" name="tipo">
                  <option value="evento">Evento</option>
                  <option value="menu">Menú del día</option>
                  <option value="aviso">Aviso</option>
                </select>
              </label>
              <label class="adm-lbl">Publicado
                <input class="adm-inp" type="date" name="publicado" required />
              </label>
              <label class="adm-lbl">Visible hasta <span class="adm-opt">(opcional)</span>
                <input class="adm-inp" type="date" name="hasta" />
              </label>
            </div>
            <label class="adm-lbl">Texto
              <textarea class="adm-inp adm-textarea" name="body" rows="4" required maxlength="4000" placeholder="Párrafos separados por línea en blanco."></textarea>
            </label>
            <label class="adm-check">
              <input type="checkbox" name="destacado" />
              Destacar en banner (solo uno activo recomendado)
            </label>
            <p class="adm-err" id="aviso-err" hidden></p>
            <p class="adm-ok" id="aviso-ok" hidden></p>
            <button class="adm-btn" type="submit">Publicar</button>
          </form>

          <h2 class="adm-h2">Publicados</h2>
          <div class="adm-cards" id="avisos-list"></div>
          <p class="adm-empty" id="avisos-empty" hidden>Sin novedades publicadas.</p>
        </section>
      </div>
    </div>
  </main>
</AdminLayout>

<script is:inline define:vars={{ calI18nJson }}>
  window.__ADM_CAL_I18N__ = calI18nJson;
</script>
<script src="../scripts/admin-panel.js"></script>


<style>
  .adm {
    min-height: 100vh;
    padding: 1.5rem 1rem 3rem;
    background: var(--bg);
  }

  .adm-brand {
    margin: 0 0 0.25rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .adm-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.15;
  }

  .adm-title--sm {
    font-size: 1.65rem;
  }

  .adm-lead,
  .adm-sub {
    margin: 0 0 1.25rem;
    color: var(--fg-muted);
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .adm-sub {
    margin: -0.25rem 0 1rem;
    font-size: 0.88rem;
  }

  .adm-card {
    max-width: 24rem;
    margin: 0 auto;
    padding: 2rem 1.75rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.35);
  }

  .adm-card--login {
    margin-top: 4vh;
  }

  .adm-back {
    margin: 1.25rem 0 0;
    text-align: center;
  }

  .adm-back__link {
    font-size: 0.88rem;
    color: var(--fg-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .adm-back__link:hover {
    color: var(--fg);
  }

  .adm-warn {
    margin: 0 0 1rem;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    color: #fde68a;
    background: rgba(250, 204, 21, 0.08);
    border: 1px solid rgba(250, 204, 21, 0.25);
    border-radius: 8px;
  }

  .adm-lbl {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .adm-lbl--inline {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.8rem;
  }

  .adm-opt {
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
    color: var(--fg-subtle);
  }

  .adm-inp {
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: var(--bg);
    color: var(--fg);
    font: inherit;
    font-size: 0.95rem;
  }

  .adm-inp--date {
    max-width: 11rem;
  }

  .adm-textarea {
    resize: vertical;
    min-height: 4rem;
  }

  .adm-form {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .adm-form--wide {
    max-width: 40rem;
  }

  .adm-err {
    margin: 0;
    color: #fca5a5;
    font-size: 0.88rem;
  }

  .adm-ok {
    margin: 0;
    color: #86efac;
    font-size: 0.88rem;
  }

  .adm-btn {
    padding: 0.7rem 1.35rem;
    border: 0;
    border-radius: 999px;
    background: var(--fg);
    color: var(--bg);
    font: inherit;
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    align-self: flex-start;
  }

  .adm-btn--ghost {
    background: transparent;
    color: var(--fg);
    border: 1px solid var(--border-strong);
  }

  .adm-btn--compact {
    padding: 0.5rem 1rem;
    font-size: 0.72rem;
  }

  .adm-link {
    margin-top: auto;
    padding: 0;
    border: 0;
    background: none;
    color: var(--fg-muted);
    font: inherit;
    font-size: 0.88rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  #dash-panel {
    display: none;
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  :global(html.adm-auth) #dash-panel {
    display: grid !important;
    visibility: visible !important;
  }

  :global(html.adm-guest) #login-panel {
    display: block;
  }

  :global(html.adm-auth) #login-panel {
    display: none !important;
  }

  @media (min-width: 900px) {
    :global(html.adm-auth) #dash-panel {
      grid-template-columns: 200px 1fr;
      align-items: start;
    }
  }

  .adm-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .adm-nav {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .adm-nav__btn {
    padding: 0.65rem 0.85rem;
    border: 0;
    border-radius: 8px;
    background: transparent;
    color: var(--fg-muted);
    font: inherit;
    font-size: 0.9rem;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .adm-nav__btn:hover,
  .adm-nav__btn.is-active {
    background: var(--bg-soft);
    color: var(--fg);
  }

  .adm-nav__btn.is-active {
    box-shadow: inset 3px 0 0 var(--fg);
  }

  .adm-main {
    min-width: 0;
  }

  .adm-panel {
    display: none;
  }

  .adm-panel.is-active {
    display: block;
  }

  .adm-head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .adm-date-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .adm-icon-btn {
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    background: var(--bg-elevated);
    color: var(--fg);
    font-size: 1.25rem;
    cursor: pointer;
    line-height: 1;
  }

  .adm-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .adm-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .adm-stat {
    padding: 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .adm-stat__val {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--fg);
    line-height: 1;
  }

  .adm-stat__lbl {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .adm-stat__hint {
    display: block;
    margin-top: 0.15rem;
    font-size: 0.72rem;
    color: var(--fg-subtle);
  }

  .adm-h2 {
    margin: 1.5rem 0 0.75rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--fg);
  }

  .adm-timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .adm-slot {
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    overflow: hidden;
  }

  .adm-slot__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
  }

  .adm-slot__time {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--fg);
  }

  .adm-slot__covers {
    font-size: 0.8rem;
    color: var(--fg-muted);
  }

  .adm-week {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .adm-week__chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 3.25rem;
    padding: 0.5rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-elevated);
    color: var(--fg-muted);
    font: inherit;
    cursor: pointer;
  }

  .adm-week__chip.is-active {
    border-color: var(--fg);
    color: var(--fg);
    background: var(--bg-soft);
  }

  .adm-week__n {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--fg);
  }

  .adm-overview-cal {
    max-width: 22rem;
    margin-bottom: 1.25rem;
  }

  .adm-new-cal {
    max-width: 22rem;
    margin-bottom: 1rem;
  }

  .adm-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.25rem;
    align-items: flex-end;
    margin-bottom: 1.25rem;
  }

  .adm-filters--cal {
    align-items: flex-start;
  }

  .adm-cal-wrap {
    flex: 1 1 16rem;
    max-width: 20rem;
  }

  .adm-lbl--filter {
    flex: 0 0 auto;
    min-width: 9rem;
  }

  .adm-cards {
    display: grid;
    gap: 0.85rem;
  }

  @media (min-width: 700px) {
    .adm-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .adm-cards--dense {
    padding: 0.75rem;
  }

  .adm-card-item {
    padding: 1rem 1.1rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .adm-card-item__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.65rem;
    margin-bottom: 0.35rem;
  }

  .adm-card-item__time {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--fg);
  }

  .adm-card-item__pax {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--fg-muted);
  }

  .adm-card-item__name {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--fg);
  }

  .adm-card-item__meta {
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .adm-card-item__meta li {
    margin: 0.2rem 0;
  }

  .adm-card-item__meta span {
    color: var(--fg-subtle);
    margin-right: 0.35rem;
  }

  .adm-card-item__notes {
    margin: 0.5rem 0 0;
    padding: 0.5rem 0.65rem;
    font-size: 0.85rem;
    font-style: italic;
    color: var(--fg-muted);
    background: var(--bg-soft);
    border-radius: 6px;
  }

  .adm-card-item__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .adm-ref {
    font-size: 0.72rem;
    color: var(--fg-subtle);
    font-family: ui-monospace, monospace;
  }

  .adm-badge {
    display: inline-block;
    padding: 0.15rem 0.45rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 4px;
  }

  .adm-badge--web {
    background: rgba(255, 255, 255, 0.08);
    color: var(--fg-muted);
  }

  .adm-badge--phone {
    background: rgba(134, 239, 172, 0.12);
    color: #86efac;
  }

  .adm-badge--status.st-pending {
    background: rgba(250, 204, 21, 0.12);
    color: #fde68a;
  }

  .adm-badge--status.st-confirmed {
    background: rgba(134, 239, 172, 0.12);
    color: #86efac;
  }

  .adm-badge--status.st-cancelled {
    background: rgba(248, 113, 113, 0.12);
    color: #fca5a5;
  }

  .adm-sel {
    font: inherit;
    font-size: 0.85rem;
    color: var(--fg);
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    padding: 0.3rem 0.4rem;
  }

  .adm-grid {
    display: grid;
    gap: 0.85rem;
  }

  @media (min-width: 600px) {
    .adm-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .adm-fieldset {
    margin: 0;
    padding: 0;
    border: 0;
  }

  .adm-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.35rem;
  }

  .adm-chip {
    display: flex;
    align-items: center;
