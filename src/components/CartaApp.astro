---
import type { CartaData } from "../data/carta";
import { ALERGENO_LABELS, ALERGENO_ORDEN, DIETA_LABELS } from "../data/carta";

interface Props {
  carta: CartaData;
  alergenoLabelsJson?: string;
  dietaLabelsJson?: string;
  uiStringsJson?: string;
}

const {
  carta,
  alergenoLabelsJson = JSON.stringify(ALERGENO_LABELS),
  dietaLabelsJson = JSON.stringify(DIETA_LABELS),
  uiStringsJson,
} = Astro.props;

const cartaJson = JSON.stringify(carta);
const alergenoLabels = JSON.parse(alergenoLabelsJson) as Record<string, string>;
const dietaLabels = JSON.parse(dietaLabelsJson) as Record<string, string>;
const ui = uiStringsJson
  ? (JSON.parse(uiStringsJson) as Record<string, string>)
  : {
      filters: "Buscar y filtrar",
      search: "Buscar",
      searchPh: "Plato o ingrediente…",
      avoidAllergens: "Evitar alérgenos",
      preferences: "Preferencias",
      clear: "Limpiar filtros",
      all: "Ver todo",
      empty: "Sin coincidencias",
      emptyHint: "Prueba otra categoría o ajusta los filtros.",
      clearInline: "Quitar filtros",
      legend: "Leyenda de alérgenos (UE 1169/2011)",
      legendFoot: "Información orientativa. Ante alergias graves, avisa siempre al personal.",
      contains: "Contiene",
      mayContain: "Puede contener",
      askRoom: "Consultar en sala",
      ingredients: "Ingredientes",
      dishes: "platos",
      dish: "plato",
      orderInSpanish: "En mesa (español)",
    };
---

<section class="carta-app" id="carta-app" aria-label="Carta interactiva">
  <div class="carta-sticky-head">
  <details class="carta-filters-panel" open>
    <summary class="carta-filters-panel__trigger">
      <span class="carta-filters-panel__icon" aria-hidden="true">⌕</span>
      <span class="carta-filters-panel__text">{ui.filters}</span>
      <span class="carta-filters-panel__badge" data-carta-filter-badge hidden>0</span>
      <span class="carta-filters-panel__chev" aria-hidden="true"></span>
    </summary>

    <div class="carta-toolbar" aria-label="Filtros de carta">
      <div class="carta-toolbar__grid">
        <div class="carta-toolbar__search">
          <label class="carta-filters__label" for="carta-search">{ui.search}</label>
          <input
            type="search"
            id="carta-search"
            class="carta-search"
            placeholder={ui.searchPh}
            autocomplete="off"
            data-carta-search
          />
        </div>

        <div class="carta-toolbar__block">
          <p class="carta-filters__label">{ui.avoidAllergens}</p>
          <div class="carta-alergenos" data-carta-alergenos role="group" aria-label="Alérgenos a excluir">
            {
              ALERGENO_ORDEN.map((id, i) => (
                <button
                  type="button"
                  class="carta-alergeno"
                  data-alergeno={id}
                  aria-pressed="false"
                  title={alergenoLabels[id]}
                >
                  <span class="carta-alergeno__num" aria-hidden="true">
                    {i + 1}
                  </span>
                  <span class="carta-alergeno__name">{alergenoLabels[id]}</span>
                </button>
              ))
            }
          </div>
        </div>

        <div class="carta-toolbar__block">
          <p class="carta-filters__label">{ui.preferences}</p>
          <div class="carta-dietas" data-carta-dietas role="group" aria-label="Filtros dietéticos">
            {
              ["sin_gluten", "sin_lactosa", "sin_huevo", "sin_pescado", "sin_marisco", "vegetariano"].map((id) => (
                <button type="button" class="carta-dieta" data-dieta={id} aria-pressed="false">
                  {dietaLabels[id] ?? id}
                </button>
              ))
            }
          </div>
        </div>
      </div>

      <div class="carta-toolbar__foot">
        <span class="carta-search__count" data-carta-count aria-live="polite"></span>
        <button type="button" class="carta-clear" data-carta-clear hidden>
          {ui.clear}
        </button>
      </div>
    </div>
  </details>

  <div class="carta-nav-bar">
    <nav class="carta-tabs" data-carta-tabs aria-label="Categorías">
      <div class="carta-tabs__fade carta-tabs__fade--l" aria-hidden="true"></div>
      <div class="carta-tabs__scroll">
        <button type="button" class="carta-tab is-active" data-cat-tab="todas" aria-selected="true">
          {ui.all}
        </button>
        {
          carta.categorias.map((cat) => (
            <button type="button" class="carta-tab" data-cat-tab={cat.id} aria-selected="false">
              {cat.subcategoria
                ? cat.subcategoria.replace(/^(Platos combinados de |Combination plates — |Assiettes combinées — )/i, "")
                : cat.categoria}
            </button>
          ))
        }
      </div>
      <div class="carta-tabs__fade carta-tabs__fade--r" aria-hidden="true"></div>
    </nav>
  </div>
  </div>

  <div class="carta-body">
    <div class="carta-empty" data-carta-empty hidden>
      <p class="carta-empty__title">{ui.empty}</p>
      <p class="carta-empty__text">{ui.emptyHint}</p>
      <button type="button" class="carta-clear carta-clear--btn" data-carta-clear-inline>
        {ui.clearInline}
      </button>
    </div>

    <div class="carta-sections" data-carta-sections>
      {
        carta.categorias.map((cat) => (
          <section class="carta-section" data-cat-section={cat.id} aria-labelledby={`cat-${cat.id}`}>
            <header class="carta-section__head">
              <h2 class="carta-section__title" id={`cat-${cat.id}`}>
                {cat.categoria}
              </h2>
              {cat.subcategoria && <p class="carta-section__sub">{cat.subcategoria}</p>}
              {cat.nota && <p class="carta-section__note">{cat.nota}</p>}
            </header>
            <ul class="carta-list">
              {cat.items.map((item) => (
                <li
                  class="carta-item"
                  data-item
                  data-buscar={item.buscar_por}
                  data-nombre={item.buscar_por.toLowerCase()}
                  data-ingredientes={item.ingredientes.join(" ").toLowerCase()}
                  data-alergenos-contiene={item.alergenos_contiene.join(",")}
                  data-alergenos-posibles={item.alergenos_posibles.join(",")}
                  data-dietas-no={item.dietas_no_apto.join(",")}
                  data-dietas-modifica={item.dietas_apto_si_modifica.join(",")}
                  data-tags={item.tags.join(",")}
                >
                  <button type="button" class="carta-item__toggle" aria-expanded="false">
                    <span class="carta-item__main">
                      {item.numero && <span class="carta-item__num">{item.numero}</span>}
                      <span class="carta-item__names">
                        <span class="carta-item__name">{item.nombre}</span>
                        {item.nombreEs && (
                          <span class="carta-item__name-es">
                            <span class="carta-item__name-es-label">{ui.orderInSpanish}</span>
                            {item.nombreEs}
                          </span>
                        )}
                      </span>
                      {item.descripcion && <span class="carta-item__desc">{item.descripcion}</span>}
                    </span>
                    <span class="carta-item__meta">
                      <span class="carta-item__price">{item.precio}</span>
                      <span class="carta-item__chev" aria-hidden="true"></span>
                    </span>
                  </button>
                  <div class="carta-item__detail" hidden>
                    {item.ingredientes.length > 0 && (
                      <p class="carta-item__ing">
                        <strong>{ui.ingredients}</strong>
                        <span>{item.ingredientes.join(", ")}</span>
                      </p>
                    )}
                    {(item.alergenos_contiene.length > 0 || item.alergenos_posibles.length > 0) && (
                      <div class="carta-item__alerg">
                        {item.alergenos_contiene.length > 0 && (
                          <p>
                            <strong>{ui.contains}</strong>
                            <span>{item.alergenos_contiene.map((a) => alergenoLabels[a] ?? a).join(", ")}</span>
                          </p>
                        )}
                        {item.alergenos_posibles.length > 0 && (
                          <p class="carta-item__alerg--posible">
                            <strong>{ui.mayContain}</strong>
                            <span>{item.alergenos_posibles.map((a) => alergenoLabels[a] ?? a).join(", ")}</span>
                          </p>
                        )}
                      </div>
                    )}
                    {item.dietas_apto_si_modifica.length > 0 && (
                      <p class="carta-item__mod">
                        <strong>{ui.askRoom}</strong>
                        <span>{item.dietas_apto_si_modifica.map((d) => dietaLabels[d] ?? d).join(", ")}</span>
                      </p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>

  <details class="carta-legend">
    <summary class="carta-legend__trigger">{ui.legend}</summary>
    <div class="carta-legend__body">
      <ol class="carta-legend__list">
        {
          ALERGENO_ORDEN.map((id, i) => (
            <li>
              <span class="carta-legend__n">{i + 1}</span>
              {alergenoLabels[id]}
            </li>
          ))
        }
      </ol>
      <p class="carta-legend__foot">
        {ui.legendFoot}
      </p>
    </div>
  </details>
</section>

<script define:vars={{ cartaJson, uiStringsJson: JSON.stringify(ui) }} data-astro-rerun>
  const ui = JSON.parse(uiStringsJson);

  const state = {
    search: "",
    excludeAlergenos: new Set(),
    dietas: new Set(),
    activeTab: "todas",
  };

  function getCartaRoot() {
    return document.getElementById("carta-app");
  }

  function normalize(str) {
    return str
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
  }

  function activeFilterCount() {
    return state.excludeAlergenos.size + state.dietas.size + (state.search.trim() ? 1 : 0);
  }

  function itemMatchesFilters(li) {
    const q = normalize(state.search.trim());
    if (q) {
      const hay = [
        li.dataset.nombre ?? "",
        li.dataset.buscar ?? "",
        li.dataset.ingredientes ?? "",
        li.querySelector(".carta-item__desc")?.textContent ?? "",
      ]
        .join(" ")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");
      if (!hay.includes(q)) return false;
    }

    const contiene = (li.dataset.alergenosContiene || "").split(",").filter(Boolean);
    for (const a of state.excludeAlergenos) {
      if (contiene.includes(a)) return false;
    }

    const dietasNo = (li.dataset.dietasNo || "").split(",").filter(Boolean);
    const tags = (li.dataset.tags || "").split(",").filter(Boolean);
    const modifica = (li.dataset.dietasModifica || "").split(",").filter(Boolean);

    for (const d of state.dietas) {
      if (d === "vegetariano") {
        if (dietasNo.includes("vegetariano_estricto")) return false;
        if (dietasNo.includes("vegetariano") && !modifica.includes("vegetariano")) return false;
        const carnes = ["carne", "atun", "pescado", "marisco", "lomo", "pollo", "bacon", "jamon", "embutido", "brasa", "hamburguesa"];
        if (tags.some((t) => carnes.some((c) => t.includes(c)))) return false;
        continue;
      }
      if (dietasNo.includes(d)) return false;
    }

    return true;
  }

  function updateFilterBadge(root) {
    const n = activeFilterCount();
    const filterBadge = root.querySelector("[data-carta-filter-badge]");
    if (filterBadge) {
      filterBadge.hidden = n === 0;
      filterBadge.textContent = String(n);
    }
  }

  function updateClearVisibility(root) {
    const hasFilters = activeFilterCount() > 0;
    root.querySelectorAll("[data-carta-clear]").forEach((btn) => {
      btn.hidden = !hasFilters;
    });
    updateFilterBadge(root);
  }

  function scrollActiveTabIntoView(root) {
    const active = root.querySelector(".carta-tab.is-active");
    const tabsScroll = root.querySelector(".carta-tabs__scroll");
    if (active && tabsScroll) {
      active.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
    }
  }

  function applyFilters(root) {
    const countEl = root.querySelector("[data-carta-count]");
    const emptyEl = root.querySelector("[data-carta-empty]");
    const sectionsWrap = root.querySelector("[data-carta-sections]");
    let visibleTotal = 0;
    const sections = root.querySelectorAll("[data-cat-section]");

    sections.forEach((section) => {
      const catId = section.dataset.catSection;
      const showSection = state.activeTab === "todas" || state.activeTab === catId;
      let sectionVisible = 0;

      section.querySelectorAll("[data-item]").forEach((li) => {
        const match = itemMatchesFilters(li);
        const visible = match && showSection;
        li.hidden = !visible;

        const posibles = (li.dataset.alergenosPosibles || "").split(",").filter(Boolean);
        const hasTrazas =
          visible && state.excludeAlergenos.size > 0 && [...state.excludeAlergenos].some((a) => posibles.includes(a));
        li.classList.toggle("has-trazas", hasTrazas);

        if (visible) {
          sectionVisible++;
          visibleTotal++;
        }
      });

      const sectionHasItems = sectionVisible > 0;
      if (state.activeTab === "todas") {
        section.hidden = !sectionHasItems;
      } else {
        section.hidden = !showSection || !sectionHasItems;
      }
    });

    if (countEl) {
      const filtering = activeFilterCount() > 0;
      countEl.textContent = filtering
        ? `${visibleTotal} ${visibleTotal === 1 ? ui.dish : ui.dishes}`
        : "";
    }

    if (emptyEl) emptyEl.hidden = visibleTotal > 0;
    if (sectionsWrap) sectionsWrap.hidden = visibleTotal === 0;
    updateClearVisibility(root);
  }

  function setActiveTab(root, tabId) {
    if (!tabId) return;
    state.activeTab = tabId;
    root.querySelectorAll("[data-cat-tab]").forEach((btn) => {
      const active = btn.dataset.catTab === tabId;
      btn.classList.toggle("is-active", active);
      btn.setAttribute("aria-selected", String(active));
    });
    applyFilters(root);
    scrollActiveTabIntoView(root);
  }

  function syncFilterControls(root) {
    const searchEl = root.querySelector("[data-carta-search]");
    if (searchEl && searchEl.value !== state.search) searchEl.value = state.search;

    root.querySelectorAll("[data-alergeno]").forEach((btn) => {
      const on = state.excludeAlergenos.has(btn.dataset.alergeno);
      btn.setAttribute("aria-pressed", String(on));
      btn.classList.toggle("is-active", on);
    });

    root.querySelectorAll("[data-dieta]").forEach((btn) => {
      const on = state.dietas.has(btn.dataset.dieta);
      btn.setAttribute("aria-pressed", String(on));
      btn.classList.toggle("is-active", on);
    });
  }

  function clearFilters(root) {
    state.search = "";
    state.excludeAlergenos.clear();
    state.dietas.clear();
    syncFilterControls(root);
    setActiveTab(root, "todas");
  }

  function setupFiltersPanel(root) {
    const panel = root.querySelector(".carta-filters-panel");
    if (!panel) return;
    panel.open = true;
  }

  function initCartaApp() {
    const root = getCartaRoot();
    if (!root) return;
    setupFiltersPanel(root);
    syncFilterControls(root);
    setActiveTab(root, state.activeTab || "todas");
  }

  function bindCartaAppOnce() {
    if (document.documentElement.dataset.cartaBound === "1") return;
    document.documentElement.dataset.cartaBound = "1";

    document.addEventListener("click", (e) => {
      const root = getCartaRoot();
      if (!root || !(e.target instanceof Element) || !root.contains(e.target)) return;

      const tabBtn = e.target.closest("[data-cat-tab]");
      if (tabBtn instanceof HTMLButtonElement) {
        e.preventDefault();
        setActiveTab(root, tabBtn.dataset.catTab);
        return;
      }

      const alergenoBtn = e.target.closest("[data-alergeno]");
      if (alergenoBtn instanceof HTMLButtonElement) {
        const id = alergenoBtn.dataset.alergeno;
        const pressed = alergenoBtn.getAttribute("aria-pressed") === "true";
        alergenoBtn.setAttribute("aria-pressed", String(!pressed));
        alergenoBtn.classList.toggle("is-active", !pressed);
        if (pressed) state.excludeAlergenos.delete(id);
        else state.excludeAlergenos.add(id);
        applyFilters(root);
        return;
      }

      const dietaBtn = e.target.closest("[data-dieta]");
      if (dietaBtn instanceof HTMLButtonElement) {
        const id = dietaBtn.dataset.dieta;
        const pressed = dietaBtn.getAttribute("aria-pressed") === "true";
        dietaBtn.setAttribute("aria-pressed", String(!pressed));
        dietaBtn.classList.toggle("is-active", !pressed);
        if (pressed) state.dietas.delete(id);
        else state.dietas.add(id);
        applyFilters(root);
        return;
      }

      if (e.target.closest("[data-carta-clear], [data-carta-clear-inline]")) {
        clearFilters(root);
        return;
      }

      const toggle = e.target.closest(".carta-item__toggle");
      if (toggle instanceof HTMLButtonElement) {
        const expanded = toggle.getAttribute("aria-expanded") === "true";
        const detail = toggle.parentElement?.querySelector(".carta-item__detail");
        toggle.setAttribute("aria-expanded", String(!expanded));
        toggle.parentElement?.classList.toggle("is-open", !expanded);
        if (detail) detail.hidden = expanded;
      }
    });

    document.addEventListener("input", (e) => {
      const root = getCartaRoot();
      if (!root || !(e.target instanceof Element) || !root.contains(e.target)) return;
      const search = e.target.closest("[data-carta-search]");
      if (search instanceof HTMLInputElement) {
        state.search = search.value;
        applyFilters(root);
      }
    });

    document.addEventListener("astro:page-load", initCartaApp);
  }

  bindCartaAppOnce();
  initCartaApp();
</script>

<style>
  .carta-app {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: calc(var(--radius) + 4px);
    border: 1px solid var(--border-strong);
    background: var(--bg-soft);
    overflow: hidden;
    box-shadow: 0 28px 64px rgba(0, 0, 0, 0.4);
  }

  /* —— Cabecera fija: filtros + pestañas (móvil) —— */
  @media (max-width: 767px) {
    .carta-sticky-head {
      position: sticky;
      top: 3.75rem;
      z-index: 13;
      background: var(--bg-soft);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.28);
    }

    .carta-filters-panel__trigger {
      display: none;
    }

    .carta-filters-panel .carta-toolbar {
      padding: 0.75rem 1rem 0.65rem;
    }

    .carta-toolbar__grid {
      gap: 0.75rem;
    }

    .carta-toolbar__block .carta-alergenos,
    .carta-toolbar__block .carta-dietas {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.15rem;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .carta-toolbar__block .carta-alergenos::-webkit-scrollbar,
    .carta-toolbar__block .carta-dietas::-webkit-scrollbar {
      display: none;
    }

    .carta-alergeno,
    .carta-dieta {
      scroll-snap-align: start;
      flex-shrink: 0;
    }

    .carta-nav-bar {
      position: static;
      top: auto;
      border-bottom: none;
    }
  }

  /* —— Filtros (plegable en escritorio) —— */
  .carta-filters-panel {
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, transparent 100%);
  }

  .carta-filters-panel__trigger {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.9rem 1rem;
    list-style: none;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .carta-filters-panel__trigger::-webkit-details-marker {
    display: none;
  }

  .carta-filters-panel__icon {
    font-size: 1.1rem;
    opacity: 0.7;
  }

  .carta-filters-panel__text {
    flex: 1;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--fg);
  }

  .carta-filters-panel__badge {
    min-width: 1.35rem;
    padding: 0.1rem 0.45rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-align: center;
    color: var(--bg);
    background: #c45c4a;
    border-radius: 999px;
  }

  .carta-filters-panel__chev {
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--fg-subtle);
    border-bottom: 2px solid var(--fg-subtle);
    transform: rotate(45deg);
    transition: transform 0.2s var(--ease-out);
  }

  .carta-filters-panel[open] .carta-filters-panel__chev {
    transform: rotate(-135deg);
    margin-top: 4px;
  }

  @media (min-width: 768px) {
    .carta-filters-panel__trigger {
      display: none;
    }

    .carta-filters-panel {
      border-bottom: 1px solid var(--border);
    }
  }

  .carta-toolbar {
    padding: 0 1rem 1.1rem;
  }

  @media (min-width: 768px) {
    .carta-toolbar {
      padding: 1.25rem 1.35rem 1.35rem;
    }
  }

  .carta-toolbar__grid {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  @media (min-width: 768px) {
    .carta-toolbar__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem 1.5rem;
    }

    .carta-toolbar__search {
      grid-column: 1 / -1;
    }
  }

  .carta-filters__label {
    display: block;
    margin: 0 0 0.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .carta-search {
    width: 100%;
    padding: 0.8rem 1rem;
    font-family: inherit;
    font-size: 1rem;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .carta-search:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.35);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.06);
  }

  .carta-search::placeholder {
    color: var(--fg-subtle);
  }

  .carta-alergenos,
  .carta-dietas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .carta-alergeno,
  .carta-dieta,
  .carta-tab,
  .carta-item__toggle,
  .carta-clear {
    touch-action: manipulation;
  }

  .carta-alergeno,
  .carta-dieta {
    min-height: 2.5rem;
    font-family: inherit;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition:
      color 0.2s,
      background 0.2s,
      border-color 0.2s,
      transform 0.15s var(--ease-out);
  }

  .carta-alergeno:active,
