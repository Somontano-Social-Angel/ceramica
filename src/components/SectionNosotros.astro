---
import { Image } from "astro:assets";
import { siteImages } from "../data/images";
import { useTranslations } from "../i18n";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
const photo = siteImages.diningRoom;
---

<section class="section" id="nosotros" aria-labelledby="nosotros-title">
  <div class="wrap">
    <div class="col-text">
      <p class="eyebrow">{t("nosotros.eyebrow")}</p>
      <h2 id="nosotros-title" class="h2">{t("nosotros.title")}</h2>
      <p class="p">{t("nosotros.p1")}</p>
      <p class="p">{t("nosotros.p2")}</p>
      <ul class="ticks">
        <li>{t("nosotros.tick1")}</li>
        <li>{t("nosotros.tick2")}</li>
        <li>{t("nosotros.tick3")}</li>
      </ul>
    </div>
    <div class="col-visual" aria-hidden="true">
      <div class="frame">
        <div class="frame__inner">
          <Image
            class="frame__photo"
            src={photo.src}
            alt=""
            width={photo.width}
            height={photo.height}
            widths={[400, 800]}
            sizes="(min-width: 900px) 400px, 85vw"
            loading="lazy"
            decoding="async"
            quality={82}
          />
          <div class="frame__shade"></div>
          <div class="frame__front">
            <span class="frame__line"></span>
            <p class="frame__quote">{t("nosotros.quote")}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 5rem 1.5rem;
    border-top: 1px solid var(--border);
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .wrap {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
    }
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .h2 {
    margin: 0 0 1.5rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--fg);
  }

  .p {
    margin: 0 0 1rem;
    max-width: 38rem;
    color: var(--fg-muted);
  }

  .ticks {
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .ticks li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.65rem;
    color: var(--fg-muted);
    font-size: 0.95rem;
  }

  .ticks li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--fg);
    opacity: 0.85;
  }

  .frame {
    border-radius: var(--radius);
    padding: 1px;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.04));
  }

  .frame__inner {
    position: relative;
    border-radius: calc(var(--radius) - 1px);
    background: var(--bg-elevated);
    min-height: 280px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .frame__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.42;
    transform: scale(1.03);
  }

  .frame__shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, rgba(27, 27, 27, 0.55) 0%, rgba(27, 27, 27, 0.88) 70%);
    pointer-events: none;
  }

  .frame__front {
    position: relative;
    z-index: 1;
    padding: 2.5rem 2rem;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .frame__line {
    display: block;
    width: 48px;
    height: 2px;
    background: var(--fg);
    margin-bottom: 1.5rem;
    opacity: 0.6;
  }

  .frame__quote {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    line-height: 1.45;
    color: var(--fg-muted);
  }
</style>
