---
import { useTranslations } from "../i18n";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
---

<section class="section" id="faq" aria-labelledby="faq-title">
  <div class="wrap">
    <p class="eyebrow">{t("faq.eyebrow")}</p>
    <h2 id="faq-title" class="h2">{t("faq.title")}</h2>
    <dl class="faq">
      <div class="item">
        <dt>{t("faq.q1")}</dt>
        <dd>{t("faq.a1")}</dd>
      </div>
      <div class="item">
        <dt>{t("faq.q2")}</dt>
        <dd>{t("faq.a2")}</dd>
      </div>
      <div class="item">
        <dt>{t("faq.q3")}</dt>
        <dd>{t("faq.a3")}</dd>
      </div>
      <div class="item">
        <dt>{t("faq.q4")}</dt>
        <dd>{t("faq.a4")}</dd>
      </div>
      <div class="item">
        <dt>{t("faq.q5")}</dt>
        <dd>{t("faq.a5")}</dd>
      </div>
      <div class="item">
        <dt>{t("faq.q6")}</dt>
        <dd>{t("faq.a6")}</dd>
      </div>
    </dl>
  </div>
</section>

<style>
  .section {
    padding: 4rem 1.5rem 5rem;
    border-top: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .h2 {
    margin: 0 0 2rem;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    color: var(--fg);
  }

  .faq {
    margin: 0;
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 720px) {
    .faq {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .item {
    margin: 0;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .item dt {
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--fg);
  }

  .item dd {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--fg-muted);
  }
</style>
