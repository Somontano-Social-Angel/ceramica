---
import { lpath, useTranslations } from "../i18n";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
---

<section class="section" id="firma" aria-labelledby="firma-title">
  <div class="wrap">
    <header class="head">
      <p class="eyebrow">{t("firma.eyebrow")}</p>
      <h2 id="firma-title" class="h2">{t("firma.title")}</h2>
      <p class="sub">{t("firma.sub")}</p>
    </header>
    <ul class="cards">
      <li class="card">
        <span class="card__num">01</span>
        <h3 class="card__title">{t("firma.c1t")}</h3>
        <p class="card__text">{t("firma.c1")}</p>
      </li>
      <li class="card">
        <span class="card__num">02</span>
        <h3 class="card__title">{t("firma.c2t")}</h3>
        <p class="card__text">{t("firma.c2")}</p>
      </li>
      <li class="card">
        <span class="card__num">03</span>
        <h3 class="card__title">{t("firma.c3t")}</h3>
        <p class="card__text">{t("firma.c3")}</p>
        <a class="card__link" href={lpath(locale, "/la-reto")}>{t("firma.c3link")}</a>
      </li>
      <li class="card">
        <span class="card__num">04</span>
        <h3 class="card__title">{t("firma.c4t")}</h3>
        <p class="card__text">{t("firma.c4")}</p>
      </li>
    </ul>
  </div>
</section>

<style>
  .section {
    padding: 5rem 1.5rem;
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-elevated) 50%, var(--bg) 100%);
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
  }

  .head {
    max-width: 40rem;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .h2 {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--fg);
  }

  .sub {
    margin: 0;
    color: var(--fg-muted);
    line-height: 1.7;
  }

  .cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 700px) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .card {
    padding: 1.75rem 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
    transition:
      border-color 0.25s,
      background 0.25s,
      transform 0.25s var(--ease-out);
  }

  .card:hover {
    border-color: var(--border-strong);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-3px);
  }

  .card__num {
    display: block;
    margin-bottom: 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--fg-subtle);
  }

  .card__title {
    margin: 0 0 0.65rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--fg);
    line-height: 1.25;
  }

  .card__text {
    margin: 0;
    font-size: 0.92rem;
    color: var(--fg-muted);
    line-height: 1.65;
  }

  .card__link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
