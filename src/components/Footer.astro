---
import { lpath, useTranslations } from "../i18n";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="inner">
    <div class="brand">
      <span class="brand__name">La Cerámica</span>
      <span class="brand__tag">{t("footer.tag")}</span>
    </div>
    <nav class="legal" aria-label={t("footer.legal")}>
      <a href="#">{t("footer.legalNotice")}</a>
      <a href="#">{t("footer.privacy")}</a>
      <a href="#">{t("footer.cookies")}</a>
      <a href={lpath(locale, "/admin")} class="staff">{t("footer.staff")}</a>
    </nav>
    <p class="copy">© {year} La Cerámica · Barbastro</p>
  </div>
</footer>

<style>
  .footer {
    padding: 2.5rem 1.5rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
  }

  .inner {
    max-width: var(--max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
  }

  @media (min-width: 720px) {
    .inner {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
    }
  }

  .brand__name {
    display: block;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--fg);
  }

  .brand__tag {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }

  .legal a {
    font-size: 0.8rem;
    color: var(--fg-muted);
  }

  .legal a:hover {
    color: var(--fg);
  }

  .staff {
    opacity: 0.55;
  }

  .copy {
    margin: 0;
    width: 100%;
    font-size: 0.78rem;
    color: var(--fg-subtle);
  }

  @media (min-width: 720px) {
    .copy {
      width: auto;
      margin-left: auto;
    }
  }
</style>
