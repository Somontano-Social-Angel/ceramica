---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  robots?: string;
}

const {
  title = "La Cerámica | Restaurante en Barbastro",
  description = "Bar-restaurante en el polígono La Cerámica, Barbastro: pizzas y hamburguesas al horno de leña, terraza amplia y el reto La Reto. Reserva o llama al 974 31 22 20.",
  robots,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {robots ? <meta name="robots" content={robots} /> : null}
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
