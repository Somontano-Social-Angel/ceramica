---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Admin · La Cerámica" } = Astro.props;
---

<!doctype html>
<html lang="es" class="adm-guest">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:inline>
      html.adm-guest #dash-panel {
        display: none !important;
        visibility: hidden !important;
      }
      html.adm-auth #login-panel {
        display: none !important;
      }
    </style>
  </head>
  <body class="adm-body">
    <slot />
  </body>
</html>

<style>
  .adm-body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
  }
</style>
